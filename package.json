{
  "name": "rabbithole",
  "version": "0.1.0",
  "type": "module",
  "description": "An infinite canvas for learning. Start from a document, select text, ask, and the answer branches out as a child document. Recurse forever.",
  "license": "MIT",
  "author": "Shlok Khemani",
  "homepage": "https://rabbithole.ing",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shlokkhemani/rabbithole.git"
  },
  "scripts": {
    "test": "npm run test:stage1 && npm run test:stage2 && npm run test:stage3",
    "test:stage1": "node test/stage1-verify.mjs",
    "test:stage2": "node test/stage2-verify.mjs",
    "test:stage3": "node test/stage3-base-url-verify.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "learning",
    "canvas",
    "claude-code",
    "codex",
    "agent"
  ],
  "bin": {
    "rabbithole-mcp": "./bin/mcp-server.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "marked": "^15.0.7",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=18"
  }
}
