{
  "name": "rabbithole",
  "version": "0.1.0",
  "type": "module",
  "description": "An infinite canvas for learning. Start from a document, select text, ask, and the answer branches out as a child document. Recurse forever.",
  "license": "MIT",
  "author": "Shlok Khemani",
  "homepage": "https://rabbithole.ing",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shlokkhemani/rabbithole.git"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:publish": "node scripts/build-publish.mjs",
    "check:dist": "node scripts/check-dist.mjs",
    "check:purity": "node scripts/check-ui-purity.mjs",
    "check:types": "tsc --noEmit",
    "test": "npm run test:stage1 && npm run test:stage2 && npm run test:stage3 && npm run test:stage4 && npm run test:stage5 && npm run test:stage6 && npm run test:stage7 && npm run test:stage8 && npm run test:stage9 && npm run test:stage9-idb && npm run test:stage10 && npm run test:stage10x && npm run test:stage11 && npm run test:stage12 && npm run test:stage13 && npm run test:stage14 && npm run test:stage15 && npm run test:stage16 && npm run test:stage18",
    "test:stage1": "node test/stage1-verify.mjs",
    "test:stage2": "node test/stage2-verify.mjs",
    "test:stage3": "node test/stage3-base-url-verify.mjs",
    "test:stage4": "node test/stage4-assets-verify.mjs",
    "test:stage5": "node test/stage5-pdf-verify.mjs",
    "test:stage6": "node test/stage6-image-ux-verify.mjs",
    "test:stage7": "node test/stage7-rearm-verify.mjs",
    "test:stage8": "node test/stage8-md-wire-verify.mjs",
    "test:stage9": "node test/stage9-store-contract.mjs",
    "test:stage9-idb": "node test/stage9-idb-store-contract.mjs",
    "test:stage10": "node test/stage10-web-verify.mjs",
    "test:stage10x": "node test/stage10x-kit-matrix.mjs",
    "test:stage11": "node test/fetch-proxy-worker-verify.mjs && node test/stage11-web-ingest-verify.mjs",
    "test:stage12": "node test/stage12-portability-verify.mjs",
    "test:stage13": "node test/stage13-data-edges-verify.mjs && node test/stage13-roundtrip-verify.mjs",
    "test:stage14": "node test/stage14-reducer-conformance.mjs",
    "test:stage15": "node test/stage15-security-migrations-verify.mjs",
    "test:stage16": "node test/stage16-budget-gauges.mjs",
    "test:stage18": "node test/stage18-generation-adapters-verify.mjs",
    "test:packaging": "node test/stage17-packaging-smoke.mjs",
    "calibrate:budgets": "node test/calibrate-budgets.mjs",
    "eval": "node test/evals/run-eval.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "learning",
    "canvas",
    "claude-code",
    "codex",
    "agent"
  ],
  "bin": {
    "rabbithole-mcp": "./bin/mcp-server.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "katex": "^0.18.0",
    "marked": "^18.0.0",
    "pdfjs-dist": "^4.0.379",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^1.0.2"
  },
  "devDependencies": {
    "esbuild": "0.28.1",
    "fake-indexeddb": "^6.2.5",
    "playwright": "^1.61.1",
    "typescript": "5.9.3"
  }
}
